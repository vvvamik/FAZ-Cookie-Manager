#: includes/class-dsar-shortcode.php:206
msgid "Right of Access (Article 15) — receive a copy of my data"
msgstr "Právo na přístup (článek 15) — obdržet kopii mých dat"

#: includes/class-dsar-shortcode.php:207
msgid "Right to Erasure (Article 17) — delete my data"
msgstr "Právo na výmaz (článek 17) — smazat moje data"

#: includes/class-dsar-shortcode.php:208
msgid "Right to Data Portability (Article 20) — export my data"
msgstr "Právo na přenositelnost údajů (článek 20) — exportovat moje data"

#: includes/class-dsar-shortcode.php:209
msgid "Right to Rectification (Article 16) — correct my data"
msgstr "Právo na opravu (článek 16) — opravit moje data"

#: includes/class-dsar-shortcode.php:210
msgid "Right to Restrict Processing (Article 18)"
msgstr "Právo na omezení zpracování (článek 18)"

#: includes/class-dsar-shortcode.php:211
