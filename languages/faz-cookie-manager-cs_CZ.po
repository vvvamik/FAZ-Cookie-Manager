msgstr "Právo vznést námitku (článek 21) — vznést námitku proti zpracování"

#: includes/class-dsar-shortcode.php:217
msgid "Fields marked with * are required."
msgstr "Pole označená * jsou povinná."

#: includes/class-dsar-shortcode.php:233
msgid "Full Name"
msgstr "Celé jméno"

#: includes/class-dsar-shortcode.php:238
msgid "Email Address"
msgstr "E-mailová adresa"

#: includes/class-dsar-shortcode.php:243
msgid "Request Type"
msgstr "Typ požadavku"

#: includes/class-dsar-shortcode.php:245
msgid "— Select a request type —"
msgstr "— Vyberte typ žádosti —"

#: includes/class-dsar-shortcode.php:253
msgid "Additional Information"
msgstr "Další informace"

#: includes/class-dsar-shortcode.php:254
msgid ""
"Optional: provide any additional context to help us identify your data."
msgstr ""
"Volitelné: uveďte jakýkoli doplňující kontext, který nám pomůže "
"identifikovat vaše data."

#: includes/class-dsar-shortcode.php:283
msgid "Submission rejected."
msgstr "Odeslání bylo zamítnuto."

#: includes/class-dsar-shortcode.php:297
msgid "Please enter your full name."
msgstr "Zadejte prosím své celé jméno."

#: includes/class-dsar-shortcode.php:309
msgid "Too many requests. Please wait 1 hour before submitting again."
msgstr "Příliš mnoho požadavků. Před dalším odesláním počkejte 1 hodinu."

#: includes/class-dsar-shortcode.php:314
msgid "Please select a valid request type."
msgstr "Vyberte prosím platný typ požadavku."

#: includes/class-dsar-shortcode.php:320
msgid "Your message is too long. Please limit it to 5,000 characters."
msgstr "Vaše zpráva je příliš dlouhá. Omežte ji prosím na 5 000 znaků."

#: includes/class-dsar-shortcode.php:349
msgid ""
"We could not record your request due to a server error. Please try again."
msgstr ""
"Váš požadavek se nepodařilo zaznamenat kvůli chybě serveru. Zkuste to prosím"
" znovu."

#: includes/class-dsar-shortcode.php:364
msgid ""
"Your request has been received. We will respond within 30 days as required "
"by law."
msgstr "Vaše žádost byla přijata. Odpovíme do 30 dnů, jak vyžaduje zákon."

#. translators: 1: site name, 2: name, 3: email, 4: request type, 5: date, 6:
#. message
#: includes/class-dsar-shortcode.php:424
#, php-format
msgid ""
"New data subject request received on %1$s.\n"
"\n"
"Name: %2$s\n"
"Email: %3$s\n"
"Request type: %4$s\n"
"Submitted: %5$s\n"
"\n"
"Message:\n"
"%6$s\n"
"\n"
"You must respond within 30 days (GDPR Art. 12). Reply directly to the requester's email address."
msgstr ""
"Nová žádost subjektu údajů přijata dne %1$s.\n"
"\n"
"Jméno: %2$s\n"
"E-mail: %3$s\n"
"Typ žádosti: %4$s\n"
"Odesáno: %5$s\n"
"\n"
"Zpráva:\n"
"%6$s\n"
"\n"
"Musíte odpovědět do 30 dnů (GDPR čl. 12). Odpovězte přímo na e-mailovou adresu žadatele."

#. translators: %s: admin URL to the request post
#: includes/class-dsar-shortcode.php:436
#, php-format
msgid "View logged request: %s"
msgstr "Zobrazit zaznamenaý požadavek: %s"

#. translators: 1: site name, 2: request type
#: includes/class-dsar-shortcode.php:448
#, php-format
msgid "[%1$s] Data Subject Request: %2$s"
msgstr "[%1$s] Žádost subjektu údajů: %2$s"

#. translators: %s: site name
#: includes/class-dsar-shortcode.php:464
#, php-format
msgid "[%s] We received your data request"
msgstr "[%s] Obdrželi jsme vaši žádost o data"

#. translators: 1: first name, 2: site name, 3: human-readable request type
#. (e.g. "Right of Access (Art. 15 GDPR)")
#: includes/class-dsar-shortcode.php:467
#, php-format
msgid ""
"Dear %1$s,\n"
"\n"
"We have received your data subject request (%3$s) on %2$s.\n"
"\n"
"We will process your request and respond within 30 days as required by GDPR Article 12.\n"
"\n"
"If you have any questions, please reply to this email.\n"
"\n"
"Thank you,\n"
"The %2$s team"
msgstr ""
"Vážený/á %1$s,\n"
"\n"
"obdrželi jsme vaši žádost subjektu údajů (%3$s) dne %2$s.\n"
"\n"
"Vaši žádost zpracujeme a odpovíme do 30 dnů v souladu s článkem 12 GDPR.\n"
"\n"
"Máte-li jakékoli dotazy, odpovězte na tento e-mail.\n"
"\n"
"Děkujeme,\n"
"Tým %2$s"

