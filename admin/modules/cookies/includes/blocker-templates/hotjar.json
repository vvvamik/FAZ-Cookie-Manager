{
    "id": "hotjar",
    "name": "Hotjar",
    "description": "Blocks Hotjar heatmaps and session recordings.",
    "category": "analytics",
    "patterns": [
        "static.hotjar.com",
        "hotjar.com/c/hotjar",
        "_hjSettings"
    ],
    "cookies": [
        "_hjid",
        "_hjSessionUser_*",
        "_hjSession_*",
        "_hjAbsoluteSessionInProgress",
        "_hjFirstSeen",
        "_hjIncludedInPageviewSample"
    ]
}
