{
  "$schema": "../schemas/ruleset.schema.json",
  "id": "mcdpa-minnesota",
  "version": "1.0.0",
  "display_name": "MCDPA — Minnesota",
  "law_references": [
    "State law MN comprehensive privacy",
    "Aligned with IAB GPP framework"
  ],
  "applies_to": {
    "countries": [
      "US"
    ],
    "regions": [
      "US-MN"
    ]
  },
  "model": "opt-out-with-sensitive-opt-in",
  "native_lang": "en",
  "official_resources_url": [
    "https://www.ag.state.mn.us/Office/Communications/2024/05/24_consumerDataPrivacy.asp"
  ],
  "signals": {
    "tcf_v22": false,
    "gpp": {
      "enabled": true,
      "section": "usmn"
    },
    "gpc_honored": false,
    "gpc_required": false,
    "dnt_honored": false,
    "cmv2": {
      "ad_storage": "denied-until-action",
      "analytics_storage": "denied-until-action",
      "ad_user_data": "denied-until-action",
      "ad_personalization": "denied-until-action",
      "personalization_storage": "granted",
      "functionality_storage": "granted",
      "security_storage": "granted"
    }
  },
  "ui": {
    "equal_weight_buttons": true,
    "donotsell_link_required": true,
    "sensitive_separate_optin": true,
    "revisit_widget_required": true,
    "default_categories": {
      "necessary": "granted-locked",
      "functional": "granted",
      "analytics": "granted",
      "marketing": "granted",
      "profiling": "denied-until-action"
    }
  },
  "cross_border_notes": null,
  "_meta": {
    "behavior_review_date": "2026-05-20",
    "next_review_due": "2027-05-20",
    "notes": "Profiling opt-in."
  }
}
