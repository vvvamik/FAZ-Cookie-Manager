{
  "$schema": "../schemas/ruleset.schema.json",
  "id": "pdpd-vietnam",
  "version": "1.0.0",
  "display_name": "PDPD — Vietnam (MPS)",
  "law_references": [
    "Decree 13/2023 (PDPD)"
  ],
  "applies_to": {
    "countries": [
      "VN"
    ]
  },
  "model": "opt-in",
  "native_lang": "vi",
  "official_resources_url": [
    "https://english.mic.gov.vn/"
  ],
  "signals": {
    "tcf_v22": false,
    "gpp": {
      "enabled": false,
      "section": null
    },
    "gpc_honored": false,
    "gpc_required": false,
    "dnt_honored": false,
    "cmv2": {
      "ad_storage": "denied",
      "analytics_storage": "denied",
      "ad_user_data": "denied",
      "ad_personalization": "denied",
      "personalization_storage": "denied",
      "functionality_storage": "granted",
      "security_storage": "granted"
    }
  },
  "ui": {
    "equal_weight_buttons": true,
    "donotsell_link_required": false,
    "sensitive_separate_optin": true,
    "revisit_widget_required": true,
    "default_categories": {
      "necessary": "granted-locked",
      "functional": "denied",
      "analytics": "denied",
      "marketing": "denied",
      "profiling": "denied"
    }
  },
  "cross_border_notes": {
    "cross_border_restrictions": "severe"
  },
  "_meta": {
    "behavior_review_date": "2026-05-20",
    "next_review_due": "2027-05-20",
    "notes": "Stretto opt-in. Cross-border restrictions severe."
  }
}
