{
  "$schema": "../schemas/ruleset.schema.json",
  "id": "pipl-china",
  "version": "1.0.0",
  "display_name": "PIPL — China (CAC)",
  "law_references": [
    "PIPL (in vigore 2021-11-01) Art. 13/24/38-43"
  ],
  "applies_to": {
    "countries": [
      "CN"
    ]
  },
  "model": "opt-in",
  "native_lang": "zh-CN",
  "official_resources_url": [
    "https://www.cac.gov.cn/"
  ],
  "signals": {
    "tcf_v22": false,
    "gpp": {
      "enabled": false,
      "section": null
    },
    "gpc_honored": false,
    "gpc_required": false,
    "dnt_honored": false,
    "cmv2": {
      "ad_storage": "denied",
      "analytics_storage": "denied",
      "ad_user_data": "denied",
      "ad_personalization": "denied",
      "personalization_storage": "denied",
      "functionality_storage": "granted",
      "security_storage": "granted"
    }
  },
  "ui": {
    "equal_weight_buttons": true,
    "donotsell_link_required": false,
    "sensitive_separate_optin": true,
    "revisit_widget_required": true,
    "default_categories": {
      "necessary": "granted-locked",
      "functional": "denied",
      "analytics": "denied",
      "marketing": "denied",
      "profiling": "denied"
    }
  },
  "cross_border_notes": {
    "requires_separate_consent_sensitive": true,
    "cross_border_mechanism": "Standard Contract (Art. 38) or CAC security assessment (Art. 40)",
    "admin_attestation_required": true
  },
  "_meta": {
    "behavior_review_date": "2026-05-20",
    "next_review_due": "2027-05-20",
    "notes": "PIPL Art. 13 separate consent for sensitive. Q9 attestation UI in P6."
  }
}
