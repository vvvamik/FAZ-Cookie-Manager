# wp.org assets + publishing guide (local only — never shipped, never tracked)
# Excluded from the wp.org ZIP via .distignore and from git via this rule.
# Screenshots are regenerated locally with scripts/capture-wporg-screenshots.mjs
# and consumed by scripts/svn-release.sh from the working tree. PUBLISHING-GUIDE.md
# is the local SVN deploy runbook (kept off the public history).
# blueprint.json is tracked (wp.org Playground Live Preview — SVN assets/).
.wordpress-org/*
!.wordpress-org/blueprint.json

# Playwright
.playwright-mcp/
tests/e2e/reports/
test-results/
playwright-report/

