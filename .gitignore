# wp.org assets + publishing guide (local only — never shipped, never tracked)
# Excluded from the wp.org ZIP via .distignore and from git via this rule.
# Screenshots are regenerated locally with scripts/capture-wporg-screenshots.mjs
# and consumed by scripts/svn-release.sh from the working tree. PUBLISHING-GUIDE.md
# is the local SVN deploy runbook (kept off the public history).
# blueprint.json is tracked (wp.org Playground Live Preview — SVN assets/).
.wordpress-org/*
!.wordpress-org/blueprints/
.wordpress-org/blueprints/*
!.wordpress-org/blueprints/blueprint.json

# Playwright
.playwright-mcp/
tests/e2e/reports/
test-results/
playwright-report/

# Planning docs (local only)
plan.md
cookie-banner-compliance-checklist.md
.claude/

# Knowledge graphs (local analysis, not tracked)
graphify-out/
.code-review-graph/
.serena/
.symdex/
*.graphml
*.canvas
/obsidian/
/raw/

# Test artifacts that occasionally leak into the working tree
#  - cookies.txt: Netscape cookie jar written by curl during manual debug
#  - /wp-content/: fixture-plugin staging directory that test helpers
#    sometimes mirror into the repo root (the real fixtures live in
#    tests/e2e/fixtures/plugins/ and the WP test site mounts them under
#    /Users/fabio/Sites/faz-test/wp-content/plugins/)
cookies.txt
/wp-content/
# Probe scripts created on-the-fly during debugging (probe-youtube.mjs etc.)
/probe-*.mjs

# Local agent instructions — never committed to wp.org/GitHub releases
CLAUDE.md
.claude/
